[Unit]
Description=Amazon Wishlist Deal Tracker
After=network.target

[Service]
Type=simple
User=wishlist
Group=wishlist
WorkingDirectory=/opt/amazon-wishlist
Environment="WISHLIST_PORT=9060"
Environment="PLAYWRIGHT_BROWSERS_PATH=/opt/amazon-wishlist/.cache/playwright"
Environment="HOME=/opt/amazon-wishlist"
Environment="XDG_RUNTIME_DIR=/tmp/runtime-wishlist"
ExecStart=/opt/amazon-wishlist/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 9060
Restart=on-failure
RestartSec=5

# Hardening
# NOTE: chromium's multi-process model (zygote / crashpad / IPC sockets) is
# fragile under systemd PrivateTmp and ProtectHome. We keep NoNewPrivileges
# and a softened ProtectSystem; PrivateTmp is dropped because chromium's
# child processes share /tmp socket paths the parent set up.
NoNewPrivileges=true
ProtectSystem=false
PrivateTmp=false
ReadWritePaths=/opt/amazon-wishlist/data /opt/amazon-wishlist/.cache

[Install]
WantedBy=multi-user.target
